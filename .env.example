# =====================================================================
# Dialog — example env file. Place this in the same directory as the
# app binary (next to Dialog.exe / dialog / dialog.AppImage) as ".env"
# to override defaults baked into the build. The packaged builds of
# Dialog do NOT include any .env by design (security: never ship DB
# credentials to end users). Copy this file to .env on first run.
# =====================================================================

# ---------- Database (REQUIRED) ----------
# Without DB_HOST the server refuses to start. Use either the DB_*
# vars below (preferred — credentials stay out of logs/stack traces)
# or a single DATABASE_URL — see server.js header for details.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=dialog
DB_PASS=changeme
DB_NAME=dialog

# Set true for managed MySQL/TiDB Cloud (TLS):
# DB_SSL=true

# ---------- Cache (optional) ----------
# Without REDIS_URL the server falls back to in-memory cache; sessions
# still persist in MySQL, so the app keeps working just slower.
# REDIS_URL=redis://127.0.0.1:6379

# ---------- WebRTC ----------
# Sign in at https://www.metered.ca and grab a free API key for TURN
# relay (mandatory for calls behind symmetric NAT — mobile networks).
# METERED_API_KEY=

# ---------- Web Push (optional, improves background notifications) ----------
# Generate a VAPID pair once:
#   npx web-push generate-vapid-keys
# VAPID_PUBLIC=
# VAPID_PRIVATE=
# VAPID_SUBJECT=mailto:admin@your-domain

# ---------- LiveKit (optional SFU for group/1v1 video) ----------
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# ---------- Port ----------
# PORT=3000

# ---------- Server region tag (telemetry/UI only) ----------
# SERVER_REGION=local
