<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>xyz.dialogmsg.app</id>

  <name>Dialog</name>
  <summary>Chat, group calls and screen sharing</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <developer id="xyz.dialogmsg">
    <name>Dialog Messanger App</name>
  </developer>

  <description>
    <p>
      Dialog is a fast, modern messenger for text chat, group voice and video
      calls, and screen sharing. This desktop client gives you native
      notifications, a system tray, and a frameless boot experience.
    </p>
    <p>Features:</p>
    <ul>
      <li>One-to-one and group messaging</li>
      <li>Group voice and video calls</li>
      <li>Screen sharing</li>
      <li>Native desktop notifications and tray integration</li>
    </ul>
  </description>

  <launchable type="desktop-id">xyz.dialogmsg.app.desktop</launchable>

  <url type="homepage">https://dialogmsg.xyz</url>
  <url type="bugtracker">https://github.com/VanylixCODER/Dialog/issues</url>

  <screenshots>
    <screenshot type="default">
      <caption>Dialog secure boot screen</caption>
      <image>https://github.com/VanylixCODER/Dialog/releases/download/v1.0.1/screenshot.png</image>
    </screenshot>
  </screenshots>

  <content_rating type="oars-1.1">
    <content_attribute id="social-chat">intense</content_attribute>
    <content_attribute id="social-audio">intense</content_attribute>
  </content_rating>

  <branding>
    <color type="primary" scheme_preference="light">#00ff5a</color>
    <color type="primary" scheme_preference="dark">#000700</color>
  </branding>

  <releases>
    <release version="1.0.1" date="2026-06-30">
      <description>
        <p>First release of the Dialog desktop client.</p>
      </description>
    </release>
  </releases>
</component>
