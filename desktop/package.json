{
  "name": "dialog-desktop",
  "productName": "Dialog",
  "version": "1.0.2",
  "description": "Dialog — cross-platform desktop client (Chat · Group calls · Screen share)",
  "homepage": "https://dialogmsg.xyz",
  "author": {
    "name": "Dialog Messanger App",
    "email": "vanylix@proton.me"
  },
  "license": "AGPL-3.0-or-later",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:arch": "electron-builder --linux pacman",
    "dist:flatpak": "electron-builder --linux flatpak",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "publish": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.2.1"
  },
  "build": {
    "appId": "xyz.dialogmsg.app",
    "productName": "Dialog",
    "copyright": "Copyright © 2026 Dialog Messanger App",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "VanylixCODER",
        "repo": "Dialog"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "pacman"
      ],
      "category": "Network",
      "icon": "assets/icon.png",
      "maintainer": "Dialog Messanger App <vanylix@proton.me>"
    },
    "flatpak": {
      "runtime": "org.freedesktop.Platform",
      "runtimeVersion": "24.08",
      "sdk": "org.freedesktop.Sdk",
      "base": "org.electronjs.Electron2.BaseApp",
      "baseVersion": "24.08",
      "finishArgs": [
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--device=dri",
        "--device=all",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.kde.StatusNotifierWatcher",
        "--system-talk-name=org.freedesktop.login1",
        "--filesystem=xdg-download"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico",
      "publisherName": "Dialog Messanger App",
      "sign": "scripts/win-sign.js"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "artifactName": "${productName}-${version}-mac.${ext}",
      "category": "public.app-category.social-networking",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Dialog needs the microphone for voice and video calls.",
        "NSCameraUsageDescription": "Dialog needs the camera for video calls.",
        "NSScreenCaptureUsageDescription": "Dialog needs screen access for screen sharing."
      }
    },
    "dmg": {
      "title": "Dialog",
      "artifactName": "${productName}-${version}.${ext}"
    }
  },
  "allowScripts": {
    "electron@31.7.7": true
  }
}
