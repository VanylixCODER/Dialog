{
  "name": "dialog-desktop",
  "productName": "Dialog",
  "version": "1.0.0",
  "description": "Dialog — cross-platform desktop client (Chat · Group calls · Screen share)",
  "author": {
    "name": "Dialog",
    "email": "aram.skalper@gmail.com"
  },
  "license": "MIT",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "publish": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.2.1"
  },
  "build": {
    "appId": "xyz.dialogmsg.app",
    "productName": "Dialog",
    "copyright": "Copyright © 2026 Dialog",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "VanylixCODER",
        "repo": "Dialog"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "icon": "assets/icon.png",
      "maintainer": "Dialog <aram.skalper@gmail.com>"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.social-networking",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Dialog needs the microphone for voice and video calls.",
        "NSCameraUsageDescription": "Dialog needs the camera for video calls.",
        "NSScreenCaptureUsageDescription": "Dialog needs screen access for screen sharing."
      }
    },
    "dmg": {
      "title": "Dialog"
    }
  },
  "allowScripts": {
    "electron@31.7.7": true
  }
}
