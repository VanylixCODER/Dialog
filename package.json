    "livekit-server-sdk": "^2.15.5",
    "mysql2": "^3.22.5",
    "socket.io": "^4.7.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@lhci/cli": "0.14.0",
    "playwright": "^1.48.0",
    "socket.io-client": "^4.7.5",
    "wait-on": "^8.0.0"
  }
}
