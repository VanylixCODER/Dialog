{
  "name": "dialog",
  "version": "1.0.0",
  "description": "Простой мессенджер с видеозвонками, демонстрацией экрана и медиа",
  "author": {
    "name": "VanylixCODER",
    "email": "vanylixcoder@users.noreply.github.com"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "perf": "npm run perf:lh && npm run perf:leak",
    "perf:lh": "lhci autorun --config=./lighthouserc.json",
